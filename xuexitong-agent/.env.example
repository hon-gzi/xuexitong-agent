# ============ 大模型配置 ============
# 选择 LLM 提供商（目前支持: mimo, openai, deepseek 等）
LLM_PROVIDER=mimo

# ============ API Key 配置 ============
# 根据你选择的 LLM_PROVIDER 填写对应的 API Key
# 示例（请替换为你自己的 Key）:
# MIMO_API_KEY=tp-your-api-key-here
# OPENAI_API_KEY=sk-your-api-key-here
# DEEPSEEK_API_KEY=sk-your-api-key-here
MIMO_API_KEY=your-api-key-here

# ============ 可选配置 ============
# 邀请码（如需要）
INVITE_CODES=

# ============ 使用说明 ============
# 1. 复制此文件并重命名为 .env
# 2. 填写你的真实 API Key
# 3. .env 文件已在 .gitignore 中，不会被提交到 Git