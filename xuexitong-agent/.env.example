# ============ 大模型配置 ============
# 选择 LLM 提供商（目前支持: agnes, mimo, openai, deepseek, modelscope 等）
LLM_PROVIDER=agnes

# ============ API Key 配置 ============
# 根据你选择的 LLM_PROVIDER 填写对应的 API Key
# 示例（请替换为你自己的 Key）:
# AGNES_API_KEY=sk-your-api-key-here
# MIMO_API_KEY=tp-your-api-key-here
# OPENAI_API_KEY=sk-your-api-key-here
# DEEPSEEK_API_KEY=sk-your-api-key-here
# MODELSCOPE_API_KEY=your-modelscope-key-here
AGNES_API_KEY=your-api-key-here

# ============ 可选配置 ============
# 邀请码（如需要）
INVITE_CODES=

# ============ 支持的 LLM 提供商 ============
# agnes     - Agnes AI (agnes-2.0-flash)  ← 默认
# mimo      - Mimo AI (mimo-v2.5)
# modelscope - ModelScope (deepseek-ai/DeepSeek-V4-Pro)
# openai    - OpenAI (GPT-4/3.5, 需配合 base_url 使用)
# deepseek  - DeepSeek
# 其他兼容 OpenAI API 的服务

# ============ 使用说明 ============
# 1. 复制此文件并重命名为 .env
# 2. 填写你的真实 API Key
# 3. .env 文件已在 .gitignore 中，不会被提交到 Git